# --- Server ---
PORT=8080

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=securellm

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- LLM provider keys (provide at least one) ---
# Provider keys are read from env vars only. Never hardcode them.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Real provider model IDs the public aliases map to.
# (The public alias "claude-3-5-sonnet" is retired upstream; it is mapped
#  to a currently-valid model here. Override if you have access to another.)
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# --- Rate limiting (per API key, sliding window) ---
RATE_LIMIT_DEFAULT=30
RATE_LIMIT_WINDOW_MS=60000

# --- Seeding ---
# Optional fixed admin key used by `npm run seed` instead of a random one.
ADMIN_BOOTSTRAP_KEY=
